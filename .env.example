# ==============================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ==============================

# Meilisearch
MEILI_MASTER_KEY=请替换为随机字符串(至少16位)

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key

# Notion
NOTION_API_KEY=your_notion_integration_token
NOTION_RAG_DB_ID=your_rag_database_id
NOTION_WIKI_DB_ID=your_wiki_database_id
NOTION_HIPPO_DB_ID=your_hippocampus_database_id

# FreshRSS (与 docker-compose 保持一致)
FRESHRSS_URL=http://localhost:8080
FRESHRSS_USERNAME=admin
FRESHRSS_API_PASSWORD=your_freshrss_api_password

# Cloudflare Worker (部署后填入)
CLOUDFLARE_WORKER_URL=https://your-worker.your-subdomain.workers.dev
CLOUDFLARE_WORKER_SECRET=请替换为随机字符串

# Meilisearch 对外地址 (Cloudflare Worker 用)
MEILI_PUBLIC_HOST=your-mac-mini-ddns-or-ip
MEILI_PORT=7700
