<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  第二层：LLM Wiki 更新
  Notion RAG 切片 → DeepSeek 归纳 → Notion Wiki DB
  每天 05:30 运行（layer1 跑完后）
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hermes.layer2-wiki</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>python3</string>
    <string>HERMES_DIR/scripts/layer2_wiki.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>HERMES_DIR</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>5</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>HERMES_DIR/logs/layer2.log</string>
  <key>StandardErrorPath</key>
  <string>HERMES_DIR/logs/layer2_err.log</string>

  <key>RunAtLoad</key>
  <false/>
  <key>KeepAlive</key>
  <false/>
</dict>
</plist>
